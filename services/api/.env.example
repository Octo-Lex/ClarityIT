# ClarityIT API Configuration
# Copy this file to .env and fill in the values.
# NEVER commit real .env files to version control.

# ─── Database ───
DATABASE_URL=postgres://clarityit:clarityit@localhost:5432/clarityit?sslmode=disable

# ─── Event Transport (Phase 5) ───
NATS_URL=nats://localhost:4222

# ─── Cache (Phase 5) ───
REDIS_URL=redis://localhost:6379/0

# ─── Object Storage (Phase 5) ───
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ─── Auth ───
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-secure-random-string
# Generate with: openssl rand -base64 32
HMAC_KEY=change-me-to-a-secure-random-string

# ─── Token TTL ───
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# ─── Server ───
API_PORT=8765
