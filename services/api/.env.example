# ClarityIT API Configuration
# Copy this file to .env and fill in the values.
# NEVER commit real .env files to version control.

# ─── Environment ───
# Required in production. "development" allows insecure defaults.
CLARITY_ENV=development

# ─── Database ───
DATABASE_URL=postgres://clarityit:clarityit@localhost:5432/clarityit?sslmode=disable

# ─── Event Transport ───
NATS_URL=nats://localhost:4222

# ─── Cache ───
REDIS_URL=redis://localhost:6379/0

# ─── Object Storage ───
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=clarityit
MINIO_USE_SSL=false

# ─── Auth (REQUIRED in production, minimum 32 characters) ───
# Generate with: openssl rand -base64 48
JWT_SECRET=
# Generate with: openssl rand -base64 48
HMAC_KEY=

# ─── Token TTL ───
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# ─── Server ───
PORT=8765

# ─── Proxmox (optional) ───
PROXMOX_ENABLED=false
# PROXMOX_URL=https://192.168.3.5:8006
# PROXMOX_TOKEN_ID=user@realm!token
# PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PROXMOX_VERIFY_TLS=false

# ─── SMTP (optional) ───
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@clarityit.example.com
# SMTP_TLS_MODE=starttls

# ─── Build Info (set via CI/CD) ───
# CLARITY_VERSION=0.8.0
# CLARITY_GIT_COMMIT=abc1234

# ─── Reasoning Worker (required for reasoning-worker container) ───
# WORKER_TOKEN=<integration-key-or-service-token>
# TEAM_ID=<uuid-of-default-team>
# API_BASE_URL=http://clarityit-api:8765
# POLL_INTERVAL=5

# ─── Document Assist (v1.4 Track 3) ───
# Internal-only HTTP endpoint on the reasoning worker (port 9100).
# The Go API calls this to generate document suggestions.
# NOT exposed to host — Docker internal network only.
# WORKER_ASSIST_URL=http://clarityit-reasoning-worker:9100
# WORKER_TOKEN must be the same value in both API and reasoning-worker.

# ─── Presenton (optional presentation generation) ───
# Enable with: docker compose --profile presenton up -d
PRESENTON_ENABLED=false
PRESENTON_URL=http://presenton:80
PRESENTON_ADMIN_USER=clarityit
PRESENTON_ADMIN_PASS=
PRESENTON_GENERATION_TIMEOUT_SECONDS=120
PRESENTON_MAX_FILE_BYTES=52428800
