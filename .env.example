# ─────────────────────────────────────────────────────────────────────────────
# ClarityIT environment configuration — example values only.
# Copy to .env and replace placeholders. NEVER commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Core
CLARITY_ENV=dev                          # dev | production
DATABASE_URL=postgres://clarity:change-me@localhost:5432/clarity
JWT_SECRET=replace-with-a-secure-random-string
HMAC_KEY=replace-with-a-secure-hmac-key

# PostgreSQL (docker-compose bootstrap)
POSTGRES_USER=clarity
POSTGRES_PASSWORD=change-me
POSTGRES_DB=clarity

# Redis
REDIS_URL=redis://localhost:6379

# NATS JetStream
NATS_URL=nats://localhost:4222

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=clarity-minio
MINIO_ROOT_PASSWORD=change-me

# ─── Reasoning worker isolation ───
# The worker MUST NOT receive DATABASE_URL, NATS_URL, REDIS_URL, or
# MINIO_ENDPOINT. It talks to the API over HTTP only.
WORKER_ASSIST_URL=http://localhost:9100
WORKER_TOKEN=replace-with-a-local-dev-token

# ─── Proxmox integration (optional) ───
PROXMOX_ENABLED=false
PROXMOX_URL=https://your-proxmox-host:8006
PROXMOX_TOKEN_ID=replace-with-token-id
PROXMOX_TOKEN_SECRET=replace-with-token-secret
PROXMOX_VERIFY_TLS=false
PROXMOX_MUTATION_ENABLED=false          # enable only with a mutation window policy

# ─── Email (dev mode returns preview links) ───
# EMAIL_MODE=dev | smtp | disabled
EMAIL_MODE=dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=clarity@localhost

# ─── Approval expiry monitor ───
APPROVAL_MONITOR_ENABLED=true
APPROVAL_MONITOR_INTERVAL_SECONDS=60
APPROVAL_EXPIRING_THRESHOLD_PERCENT=80

# ─── Backups ───
BACKUP_DIR=/opt/clarityit/backups
